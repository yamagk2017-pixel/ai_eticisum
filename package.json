{
  "name": "musicite_ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --cache --cache-location .eslintcache",
    "sanity": "sanity",
    "sanity:deploy": "sanity deploy",
    "report:wp-unmatched-related-groups": "node scripts/wp-unmatched-related-groups-report.mjs --limit=10 --page=1",
    "poc:wp-to-sanity:dry-run": "node scripts/wp-to-sanity-poc-dry-run.mjs --limit=10 --page=1",
    "poc:wp-to-sanity:apply": "node scripts/wp-to-sanity-poc-dry-run.mjs --limit=10 --page=1 --apply",
    "sync:wp-taxonomies:dry-run": "node scripts/wp-sync-taxonomies-to-sanity.mjs --dry-run",
    "sync:wp-taxonomies:apply": "node scripts/wp-sync-taxonomies-to-sanity.mjs --apply",
    "report:wp-poc-issues:merge": "node scripts/merge-wp-poc-issues.mjs",
    "capture:imakite": "node scripts/capture-imakite.mjs",
    "replace:wp-image-host:dry-run": "node scripts/replace-wp-image-host-in-sanity.mjs --from=https://www.musicite.net --to=http://musicite.sub.jp",
    "replace:wp-image-host:apply": "node scripts/replace-wp-image-host-in-sanity.mjs --from=https://www.musicite.net --to=http://musicite.sub.jp --apply"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "@sanity/image-url": "^2.0.3",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "next-sanity": "^12.1.0",
    "pdf2json": "^4.0.2",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-tweet": "^3.3.0",
    "sanity": "^5.11.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
